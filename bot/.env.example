# Required
TELEGRAM_TOKEN=

# Optional — Telegram chat IDs for broadcasting sniper signals + new CTOs
GROUP_CHAT_ID=
SNIPER_CHAT_ID=

# Optional — comma-separated Telegram user IDs allowed to use admin commands
ADMIN_IDS=

# Optional — protects the /api/cto/add and /api/cto/clear endpoints
CTO_ADMIN_KEY=

# Optional — branding URLs in /start and /help messages
SITE_URL=https://iq50.io
CTO_PAGE_URL=https://iq50.io/cto.html

# Optional — only needed if you enable Claude AI analysis inside the sniper engine
ANTHROPIC_API_KEY=

# Optional — better RPC throughput (sniper has hardcoded fallbacks)
HELIUS_KEY=
MORALIS_KEY=

# Set automatically by Railway
PORT=3000
RAILWAY_VOLUME_MOUNT_PATH=
